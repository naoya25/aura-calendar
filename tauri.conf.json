{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AuraCalendar",
  "version": "0.1.0",
  "identifier": "com.naoya.auracalendar",
  "build": {
    "frontendDist": "dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png"]
  }
}
